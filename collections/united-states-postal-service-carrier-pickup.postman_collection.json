        {
          "id": "2f2db0b8-e44c-4eb2-82d8-dcb1a5178a5e",
          "name": "USPS Carrier Pickup Schedule Carrier Pickup",
          "request": {
            "name": "USPS Carrier Pickup Schedule Carrier Pickup",
            "description": {
              "content": "Schedules a free USPS carrier pickup at a specified address for the next available pickup date. Pickup is available Monday-Saturday, excluding federal holidays.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "pickup",
                "v3",
                "carrier-pickup"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickupAddress\": {\n    \"streetAddress\": \"<string>\",\n    \"city\": \"<string>\",\n    \"state\": \"<string>\",\n    \"ZIPCode\": \"<string>\",\n    \"secondaryAddress\": \"<string>\"\n  },\n  \"packages\": [\n    {\n      \"serviceType\": \"<string>\",\n      \"count\": \"<integer>\"\n    },\n    {\n      \"serviceType\": \"<string>\",\n      \"count\": \"<integer>\"\n    }\n  ],\n  \"firstName\": \"<string>\",\n  \"lastName\": \"<string>\",\n  \"packageLocation\": \"<string>\",\n  \"specialInstructions\": \"<string>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [
            {
              "id": "a1b28e69-fcaa-4151-ba45-8c097ae97417",
              "name": "Pickup scheduled successfully.",
              "originalRequest": {
                "url": {
                  "path": [
                    "pickup",
                    "v3",
                    "carrier-pickup"
                  ],
                  "host": [
