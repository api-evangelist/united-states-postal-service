{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/united-states-postal-service/refs/heads/main/json-schema/tracking-multiple-tracking-request-schema.json",
  "title": "MultipleTrackingRequest",
  "description": "Request body for multiple package tracking.",
  "type": "object",
  "properties": {
    "trackingNumbers": {
      "type": "array",
      "description": "List of USPS tracking numbers to look up (max 10).",
      "items": {
        "type": "string"
      },
      "example": [
        "9400111899223397910390",
        "9400111899223397910407"
      ]
    }
  },
  "required": [
    "trackingNumbers"
  ]
}