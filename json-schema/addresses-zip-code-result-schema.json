{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/united-states-postal-service/refs/heads/main/json-schema/addresses-zip-code-result-schema.json",
  "title": "ZIPCodeResult",
  "description": "ZIP Code lookup result.",
  "type": "object",
  "properties": {
    "streetAddress": {
      "type": "string",
      "description": "Standardized street address.",
      "example": "2 MASSACHUSETTS AVE NE"
    },
    "city": {
      "type": "string",
      "description": "City name.",
      "example": "WASHINGTON"
    },
    "state": {
      "type": "string",
      "description": "Two-letter state abbreviation.",
      "example": "DC"
    },
    "ZIPCode": {
      "type": "string",
      "description": "5-digit ZIP Code.",
      "example": "20212"
    },
    "ZIPPlus4": {
      "type": "string",
      "description": "ZIP+4 Code.",
      "example": "0001"
    }
  }
}