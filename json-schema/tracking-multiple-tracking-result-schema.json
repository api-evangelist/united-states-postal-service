{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/united-states-postal-service/refs/heads/main/json-schema/tracking-multiple-tracking-result-schema.json",
  "title": "MultipleTrackingResult",
  "description": "Tracking results for multiple packages.",
  "type": "object",
  "properties": {
    "trackingResults": {
      "type": "array",
      "description": "List of tracking results per tracking number.",
      "items": {
        "type": "object",
        "properties": {
          "trackingNumber": {
            "type": "string",
            "description": "The tracking number.",
            "example": "9400111899223397910390"
          },
          "status": {
            "type": "string",
            "description": "Current delivery status.",
            "example": "DELIVERED"
          },
          "deliveryDate": {
            "type": "string",
            "format": "date",
            "description": "Actual or estimated delivery date.",
            "example": "2025-03-14"
          }
        }
      }
    }
  }
}